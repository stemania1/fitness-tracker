NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Anthropic API key for photo-based calorie/macro estimation (/api/estimate-food).
# Server-side only — never prefix with NEXT_PUBLIC.
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Web-push reminders (optional; the reminder cron is inert without these) ---
# Generate a keypair once with:  npx web-push generate-vapid-keys
# Public key is exposed to the browser; the private key is a secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com

# Service-role key (Supabase dashboard → Project Settings → API). Server-only,
# bypasses RLS — used solely by the reminder cron to read all users' data.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Shared secret protecting /api/cron/reminders. Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>`. Any random string.
CRON_SECRET=your-cron-secret
